{
  "productName": "Xbox Battery Monitor",
  "version": "0.1.0",
  "identifier": "com.ajdad.xbox-battery",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xbox Battery Monitor",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
    
  }, 

  "plugins": {
    "notification": null
  },

  

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}